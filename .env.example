# Copy this file to .env and fill in your values

# ---------------------------------------------------------------------------
# Provider & Model Settings
# ---------------------------------------------------------------------------

# Primary API details (supports any OpenAI-compatible API base: e.g. OpenRouter, OpenAI, Groq, etc.)
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_API_KEY=your_api_key_here

# Target Models to execute
EVAL_MODEL=deepseek/deepseek-chat
SYNTH_MODEL=deepseek/deepseek-chat
FALLBACK_MODEL=deepseek/deepseek-chat-v3-0324

# Google Gemini API key (used as fallback if set)
GEMINI_API_KEY=your_gemini_api_key_here

# Local Model (set to 'none' to disable, or an Ollama model name like 'gemma4:12b-mlx' / 'deepseek-r1:14b')
LOCAL_MODEL=none

# ---------------------------------------------------------------------------
# Publisher Settings
# ---------------------------------------------------------------------------

# GitHub token (leave blank if authenticated via the `gh` CLI)
GITHUB_TOKEN=your_github_token_here
