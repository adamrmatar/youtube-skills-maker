# Copy this file to .env and fill in your values

# Google Gemini API (used as fallback or primary if set)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API (Primary for DeepSeek models to avoid Gemini rate limits)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model Selection
EVAL_MODEL=deepseek/deepseek-chat
SYNTH_MODEL=deepseek/deepseek-chat
FALLBACK_MODEL=deepseek/deepseek-chat-v3-0324

# Local Model (set to 'none' to disable, or an Ollama model like 'gemma4:12b-mlx' / 'deepseek-r1:14b')
LOCAL_MODEL=none

# GitHub configuration (Leave blank if authenticated via `gh auth login` CLI)
GITHUB_TOKEN=your_github_token_here
